# Copy this to .env and fill in your values (never commit .env to git)

# Your Vapi API key (already configured)
VAPI_API_KEY=your-vapi-api-key-here

# Optional: a secret string you choose — used to verify webhook requests are from Vapi
VAPI_WEBHOOK_SECRET=your-secret-here

# The ID from your Google Doc URL:
# https://docs.google.com/document/d/THIS_PART_IS_THE_ID/edit
GOOGLE_DOC_ID=your-google-doc-id-here

# Service account email: vapi-webhook@key-airlock-241814.iam.gserviceaccount.com
# Service account credentials JSON (paste the full JSON as a single line)
SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
